# ── Local Ollama LLM backend ──────────────────────────────────────────
# Base URL of the Ollama server. Local default is http://localhost:11434.
# (A cloudflared tunnel URL works too — see the root .env.local.)
OLLAMA_BASE_URL=http://localhost:11434
# Optional auth. Bearer token, or a Cloudflare Access service token in the
# form "<client-id>:<client-secret>". Leave empty for a plain local server.
OLLAMA_API_KEY=
# Default model used for analysis (any model from `ollama list`).
OLLAMA_CHAT_MODEL=llama3.1:8b
# How long Ollama keeps the model loaded in memory between calls.
OLLAMA_KEEP_ALIVE=30m
# Request timeout in milliseconds (local generation can be slow).
OLLAMA_TIMEOUT_MS=300000

# ── Data generation (make generate-data) ──────────────────────────────
# Alpha Vantage key for fundamentals; price data comes from yfinance.
ALPHA_VANTAGE_API_KEY=insert_key

# ── Supabase (data + outputs storage) ─────────────────────────────────
# Generated ticker data, uploaded docs, and analysis recommendations are
# stored in Supabase instead of local folders. The AlphaOS UI forwards these
# automatically; set them here only to run the CLI (make analyze / generate-data)
# standalone against Supabase. Without them, the CLI falls back to local files.
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
