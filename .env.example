# ── Bootstrap CIO admin ───────────────────────────────────────────
# The built-in admin login. Owns the "CIO Alpha" tenant (all existing data) and
# can create more users from the in-app User Management page. Additional users
# live in the `users` table, not here. AUTH_JWT_SECRET signs the app's own
# session cookie.
AUTH_USERNAME=
AUTH_PASSWORD_HASH=
AUTH_JWT_SECRET=

# Optional — built-in demo login (its own isolated, initially-empty tenant).
# Defaults to demo / demo if unset.
DEMO_USERNAME=
DEMO_PASSWORD=


NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Required for multitenancy (Option B). Mints per-request `authenticated` tokens
# whose tenant_id claim drives the RLS policies, so the database enforces tenant
# isolation. Copy from Supabase → Project Settings → API → JWT Settings → "JWT Secret".
SUPABASE_JWT_SECRET=


ALPHA_VANTAGE_API_KEY=


# ── Draft & Review email notifications (Gmail + Nodemailer) ───────
# Powers the "Notify" button in Research → Draft & Review.
# Sends to any recipient — no domain to verify.
# GMAIL_APP_PASSWORD is a 16-char App Password (needs 2-Step Verification):
#   https://myaccount.google.com/apppasswords
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=
# Optional display name; defaults to GMAIL_USER.
EMAIL_FROM=AlphaOS <you@gmail.com>


# ── AI Pipeline (prism_ai) — local Ollama LLM backend ─────────────────
# Forwarded to the Python pipeline by src/app/api/prism/run/route.js.
# Local default works out of the box if Ollama runs on this machine.
OLLAMA_BASE_URL=http://localhost:11434
# Optional auth: Bearer token, or a Cloudflare Access token "<id>:<secret>".
OLLAMA_API_KEY=
# Model used for analysis (any model from `ollama list`).
OLLAMA_CHAT_MODEL=llama3.1:8b
OLLAMA_KEEP_ALIVE=30m
# Context window; must hold the full system prompt + company data + output.
OLLAMA_NUM_CTX=16384
OLLAMA_TIMEOUT_MS=300000

# ── Prism AI pipeline LLM (Google Gemini) ─────────────────────────
# Forwarded to the Python pipeline by src/app/api/prism/run/route.js.
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash