# ── Bootstrap CIO admin login ─────────────────────────────────────
# Built-in admin account. Owns the "CIO Alpha" tenant (all existing data) and
# can create more users from the in-app User Management page. Extra users live
# in the `users` table, not here. AUTH_JWT_SECRET signs the app's session cookie.
# Generate the password hash with:  node scripts/generate-hash.mjs
AUTH_USERNAME=
AUTH_PASSWORD_HASH=
AUTH_JWT_SECRET=

# Optional — built-in demo login (its own isolated, initially-empty tenant).
# Defaults to demo / demo if unset.
# DEMO_USERNAME=
# DEMO_PASSWORD=


# ── Supabase (Postgres + RLS) ─────────────────────────────────────
# URL + anon key are public (shipped to the browser). The service-role key
# bypasses RLS and must stay server-only. SUPABASE_JWT_SECRET mints per-request
# `authenticated` tokens whose tenant_id claim drives the RLS policies, so the
# database enforces tenant isolation. All four: Supabase → Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=


# ── Market & macro data ───────────────────────────────────────────
# Alpha Vantage: equity fundamentals/prices (generate-data + prism pipeline).
# FRED: macro series for the regime allocator (St. Louis Fed, also used by the
# macro-regime GitHub workflow).
ALPHA_VANTAGE_API_KEY=
FRED_API_KEY=


# ── Macro-regime GitHub Actions dispatch ──────────────────────────
# On Vercel the heavy macro job can't run in-process, so src/app/api/macro-regime/run
# fires a repository_dispatch to run .github/workflows/macro-regime.yml.
# Token needs repo + workflow scope on GH_DISPATCH_REPO.
GH_DISPATCH_TOKEN=
GH_DISPATCH_REPO=
# Optional overrides (defaults: macro-regime.yml / main).
# GH_DISPATCH_WORKFLOW=
# GH_DISPATCH_REF=
# Set to 1 to force the dispatch path locally (off Vercel) for testing.
# MACRO_RUN_DISABLED=


# ── Draft & Review email notifications (Gmail + Nodemailer) ───────
# Powers the "Notify" button in Research → Draft & Review. Sends to any
# recipient — no domain to verify. GMAIL_APP_PASSWORD is a 16-char App Password
# (needs 2-Step Verification): https://myaccount.google.com/apppasswords
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=
# Optional display name; defaults to GMAIL_USER.
EMAIL_FROM=AlphaOS <you@gmail.com>


# ── Draft & Review auto-notify cron ───────────────────────────────
# Secret guarding GET|POST /api/cron/auto-notify, which fires Draft & Review
# reminders on a schedule — even when nobody has the review open. Set to a long
# random string (openssl rand -hex 32). On Vercel, add it as the CRON_SECRET
# project env var and Vercel Cron (see vercel.json) sends it automatically as
# `Authorization: Bearer …`. Other schedulers may pass it via that header,
# `x-cron-secret: <secret>`, or `?secret=<secret>`. Unset ⇒ endpoint returns 401.
CRON_SECRET=


# ── Prism AI pipeline LLM (Google Gemini) ─────────────────────────
# The prism_ai analysis pipeline runs on Gemini. Forwarded to the Python process
# by the research API routes. Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# Optional — User-Agent string for SEC EDGAR requests made by the pipeline.
# SEC_USER_AGENT=
